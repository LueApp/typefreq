          emptyTypos: '还没有错词记录。',
          emptyCustomWords: '还没有自定义词。',
          leaderboardCaptionOne: '{period} - 显示 {count} 个词',
          leaderboardCaptionMany: '{period} - 显示 {count} 个词',
          keep: '保留',
          removeLabel: '移除 {word}',
          customAdded: '已添加“{word}”。',
          customAlreadyKept: '“{word}”已经保留。',
          customRemoved: '已移除“{word}”。',
          customNotInList: '“{word}”不在列表中。',
