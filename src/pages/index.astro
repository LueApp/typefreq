---
import '../styles/site.css';

const downloadHref = '/downloads/typefreq-latest.tar';
const repoHref = 'https://github.com/LueApp/typefreq';
const defaultTitle = 'Typefreq - typing analytics';
const defaultDescription = 'Open the public Typefreq web UI. It displays local typing analytics when the desktop service is installed, and shows setup guidance when it is not.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{defaultTitle}</title>
    <meta name="description" content={defaultDescription} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? 'https://typefreq.lue-app.com')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={defaultTitle} />
    <meta property="og:description" content={defaultDescription} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site ?? 'https://typefreq.lue-app.com')} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="app-shell">
      <header class="app-header">
        <a class="brand" href="/" aria-label="Typefreq home" data-i18n-aria="brandHomeLabel">
          <span class="brand-mark">t</span>
          <span>Typefreq</span>
        </a>
        <span id="connection-badge" class="status-pill checking" data-i18n="statusChecking">checking local service</span>
        <label class="language-control" for="language-select">
          <span data-i18n="languageLabel">Language</span>
          <select id="language-select" aria-label="Language" data-i18n-aria="languageLabel">
            <option value="en" data-i18n="languageEnglish">English</option>
            <option value="zh" data-i18n="languageChinese">中文</option>
          </select>
        </label>
        <form id="port-form" class="port-control">
          <label for="port-input" data-i18n="localPort">Local port</label>
          <input id="port-input" type="number" inputmode="numeric" min="1024" max="65535" step="1" value="8788" />
          <button class="btn" type="submit" data-i18n="apply">Apply</button>
        </form>
        <div class="header-actions">
          <button id="retry-btn" class="btn" type="button" data-i18n="retry">Retry</button>
          <button id="pause-btn" class="btn" type="button" hidden data-i18n="pause">Pause</button>
          <button id="download-installer-btn" class="btn primary" type="button" data-download-href={downloadHref} data-i18n="downloadInstaller">Download installer</button>
        </div>
      </header>

      <main class="app-main">
        <section id="dashboard-view" class="dashboard-view" hidden>
          <div class="summary-row">
            <article class="stat-card">
              <span class="stat-label" data-i18n="wordsToday">Words today</span>
              <strong id="stat-words">-</strong>
            </article>
            <article class="stat-card">
              <span class="stat-label" data-i18n="uniqueToday">Unique today</span>
              <strong id="stat-unique">-</strong>
            </article>
            <article class="stat-card">
              <span class="stat-label" data-i18n="typosToday">Typos today</span>
              <strong id="stat-typos">-</strong>
            </article>
            <article class="stat-card">
              <span class="stat-label" data-i18n="eventsSeen">Events seen</span>
              <strong id="stat-events">-</strong>
            </article>
          </div>

          <section id="service-notice" class="notice" hidden></section>

          <div class="dashboard-grid">
            <section class="panel">
              <div class="panel-head">
                <h2 data-i18n="topWords">Top words</h2>
                <div id="leaderboard-tabs" class="tabs" role="tablist" aria-label="Leaderboard period" data-i18n-aria="leaderboardPeriod">
                  <button class="tab active" type="button" data-period="today" data-i18n="periodToday">Today</button>
                  <button class="tab" type="button" data-period="week" data-i18n="periodWeek">Week</button>
                  <button class="tab" type="button" data-period="month" data-i18n="periodMonth">Month</button>
                  <button class="tab" type="button" data-period="year" data-i18n="periodYear">Year</button>
                  <button class="tab" type="button" data-period="alltime" data-i18n="periodAll">All</button>
                </div>
              </div>
              <p id="leaderboard-caption" class="panel-caption"></p>
              <div id="top-list" class="top-list"></div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <h2 data-i18n="hourlyActivity">Hourly activity</h2>
              </div>
              <div id="hourly-list" class="hourly-list"></div>
            </section>

            <section class="panel wide">
              <div class="panel-head">
                <h2 data-i18n="recentTypos">Recent typos</h2>
              </div>
              <div id="typo-list" class="typo-list"></div>
            </section>

            <section class="panel wide">
              <div class="panel-head">
                <h2 data-i18n="customWords">Custom words</h2>
                <span class="panel-caption" data-i18n="customWordsCaption">Words that should not be flagged as typos.</span>
              </div>
              <div id="custom-list" class="chips"></div>
              <form id="custom-form" class="add-row">
                <input id="custom-input" type="text" placeholder="Add a word" autocomplete="off" data-i18n-placeholder="addWordPlaceholder" />
                <button class="btn primary" type="submit" data-i18n="add">Add</button>
              </form>
              <p id="custom-feedback" class="feedback"></p>
            </section>
          </div>
        </section>

        <section id="setup-view" class="setup-view">
          <div class="setup-intro">
            <p id="intro-eyebrow" class="eyebrow" data-i18n="setupEyebrow">Local service not detected</p>
            <h1 id="intro-title" data-i18n="setupTitle">Install Typefreq, then this page becomes your dashboard.</h1>
            <p class="lead">
              <span id="intro-lead-before" data-i18n="setupLeadBefore">This public page reads the desktop service running on your own Ubuntu machine at </span><code id="local-api-label">127.0.0.1:8788</code><span id="intro-lead-after" data-i18n="setupLeadAfter">. If the service is installed and running on the selected port, your data appears here automatically. If it is not installed yet, follow the steps below.</span>
            </p>
            <div id="setup-actions" class="button-row">
              <button id="setup-download-installer-btn" class="btn primary" type="button" data-i18n="downloadConfiguredInstaller">Download configured installer</button>
              <a class="btn" href={downloadHref} download data-i18n="sourcePackage">Source package</a>
              <a class="btn" href={repoHref} target="_blank" rel="noopener noreferrer" data-i18n="viewSource">View source</a>
              <button id="setup-retry-btn" class="btn" type="button" data-i18n="installedRetry">I installed it, retry</button>
            </div>
          </div>

          <div id="setup-guide" class="setup-grid">
            <article id="w2l-card" class="setup-card primary-card web2local-card">
              <div class="w2l-head">
                <div>
                  <p class="eyebrow" data-i18n="w2lEyebrow">No terminal path</p>
                  <h2 data-i18n="w2lTitle">Install with web2local</h2>
                </div>
                <span id="w2l-status" class="w2l-status" data-state="checking" data-i18n="w2lChecking">checking web2local</span>
              </div>
              <p>
                <span data-i18n="w2lBodyBefore">Already running </span><a href="https://web2local-bridge.lue-app.com/" target="_blank" rel="noopener noreferrer">web2local</a><span data-i18n="w2lBodyAfter">? It can write and run a configured installer after you approve it. If first-time sudo setup is needed, use the terminal installer below.</span>
              </p>
              <div class="w2l-controls">
                <label for="w2l-port-input" data-i18n="w2lPortLabel">web2local port</label>
                <input id="w2l-port-input" type="number" inputmode="numeric" min="1" max="65535" step="1" value="7878" />
                <button id="w2l-check-btn" class="btn" type="button" data-i18n="w2lCheck">Check</button>
              </div>
              <div class="button-row">
                <button id="w2l-install-btn" class="btn primary" type="button" data-i18n="w2lInstall">Install Typefreq</button>
                <a id="w2l-get-link" class="btn" href="https://web2local-bridge.lue-app.com/" target="_blank" rel="noopener noreferrer" hidden data-i18n="w2lGet">Get web2local</a>
              </div>
              <p id="w2l-message" class="small-note"></p>
              <pre id="w2l-log" class="w2l-log" hidden></pre>
            </article>

            <article class="setup-card">
              <h2 data-i18n="fastPathTitle">Fast path on Ubuntu</h2>
              <p data-i18n="fastPathBody">The installer handles Python packages, the virtual environment, the user service, and autostart.</p>
              <pre><code id="install-command">bash typefreq-install-8788.sh</code></pre>
              <p class="small-note"><span data-i18n="fastPathNoteBefore">The configured installer downloads the package and installs the service on your selected port. You can also extract the source package and run </span><code id="manual-install-command">./install.sh 8788</code><span data-i18n="fastPathNoteAfter">.</span></p>
            </article>

            <article class="setup-card">
              <h2 data-i18n="installerDoesTitle">What the installer does</h2>
              <ul class="plain-list">
                <li data-i18n="installerDoesApt">Installs common Ubuntu dependencies with apt when available.</li>
                <li data-i18n="installerDoesVenv">Creates a Python virtual environment and installs Python requirements.</li>
                <li><span data-i18n="installerDoesServiceBefore">Enables </span><code>typefreq.service</code><span data-i18n="installerDoesServiceAfter"> as a systemd user service.</span></li>
                <li data-i18n="installerDoesLocalhost">Keeps the API bound to localhost so data is not exposed publicly.</li>
              </ul>
            </article>

            <article class="setup-card">
              <h2 data-i18n="stillNoConnectTitle">If it still does not connect</h2>
              <pre><code>systemctl --user status typefreq.service
journalctl --user -u typefreq -n 40 --no-pager</code></pre>
              <p class="small-note" data-i18n="stillNoConnectNote">The most common first-install issue is needing one sign-out/sign-in after the installer adds keyboard-input permission.</p>
            </article>
          </div>
        </section>
      </main>
    </div>

