          customNotInList: '“{word}”不在列表中。',
          couldNotAddWord: '无法添加这个词。',
        },
      };

      const els = {
        badge: document.getElementById('connection-badge'),
        languageSelect: document.getElementById('language-select'),
        portForm: document.getElementById('port-form'),
        portInput: document.getElementById('port-input'),
        introEyebrow: document.getElementById('intro-eyebrow'),
        introTitle: document.getElementById('intro-title'),
        introLeadBefore: document.getElementById('intro-lead-before'),
        introLeadAfter: document.getElementById('intro-lead-after'),
        localApiLabel: document.getElementById('local-api-label'),
        installCommand: document.getElementById('install-command'),
        manualInstallCommand: document.getElementById('manual-install-command'),
        w2lCard: document.getElementById('w2l-card'),
        w2lStatus: document.getElementById('w2l-status'),
        w2lPortInput: document.getElementById('w2l-port-input'),
        w2lCheck: document.getElementById('w2l-check-btn'),
        w2lInstall: document.getElementById('w2l-install-btn'),
        w2lGet: document.getElementById('w2l-get-link'),
        w2lMessage: document.getElementById('w2l-message'),
        w2lLog: document.getElementById('w2l-log'),
        downloadInstaller: document.getElementById('download-installer-btn'),
        setupDownloadInstaller: document.getElementById('setup-download-installer-btn'),
        setupActions: document.getElementById('setup-actions'),
        setupGuide: document.getElementById('setup-guide'),
        dashboard: document.getElementById('dashboard-view'),
        setup: document.getElementById('setup-view'),
        retry: document.getElementById('retry-btn'),
        setupRetry: document.getElementById('setup-retry-btn'),
        pause: document.getElementById('pause-btn'),
        words: document.getElementById('stat-words'),
        unique: document.getElementById('stat-unique'),
        typos: document.getElementById('stat-typos'),
        events: document.getElementById('stat-events'),
        notice: document.getElementById('service-notice'),
        topList: document.getElementById('top-list'),
        hourlyList: document.getElementById('hourly-list'),
        typoList: document.getElementById('typo-list'),
        customList: document.getElementById('custom-list'),
        customForm: document.getElementById('custom-form'),
        customInput: document.getElementById('custom-input'),
        customFeedback: document.getElementById('custom-feedback'),
        leaderboardCaption: document.getElementById('leaderboard-caption'),
      };

      let refreshTimer = null;
      let activePeriod = 'today';
      let leaderboards = null;
      let latestStatus = null;
      let connectionMode = 'checking';
      let servicePort = loadPort();
      let w2lPort = loadW2lPort();
      let w2lState = 'checking';
      let w2lBusy = false;
      let w2lMessageKey = '';
      let w2lMessageValues = null;
      let currentLanguage = loadLanguage();

      function esc(value) {
        return String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      }

      function t(key) {
        return translations[currentLanguage]?.[key] ?? translations.en[key] ?? key;
      }

      function phrase(key, values = {}) {
        return t(key).replace(/\{(\w+)\}/g, (_, name) => String(values[name] ?? ''));
      }

      function fmt(value) {
        return Number(value || 0).toLocaleString(t('locale'));
      }

      function fmtTime(ts) {
        return new Date(ts * 1000).toLocaleTimeString(t('locale'), { hour: '2-digit', minute: '2-digit' });
      }

      function isValidPort(value) {
        return /^[0-9]+$/.test(String(value)) && Number(value) >= 1024 && Number(value) <= 65535;
      }

      function isValidAnyPort(value) {
        return /^[0-9]+$/.test(String(value)) && Number(value) >= 1 && Number(value) <= 65535;
      }

      function loadPort() {
        const stored = localStorage.getItem(PORT_STORAGE_KEY);
        return isValidPort(stored) ? Number(stored) : DEFAULT_PORT;
      }

      function loadW2lPort() {
        const stored = localStorage.getItem(W2L_PORT_STORAGE_KEY);
        return isValidAnyPort(stored) ? Number(stored) : W2L_DEFAULT_PORT;
      }

      function loadLanguage() {
        const stored = localStorage.getItem(LANGUAGE_STORAGE_KEY);
        return translations[stored] ? stored : DEFAULT_LANGUAGE;
      }

      function syncLanguageStaticText() {
        document.documentElement.lang = t('htmlLang');
        document.title = t('metaTitle');
        document.querySelector('meta[name="description"]')?.setAttribute('content', t('metaDescription'));
        document.querySelector('meta[property="og:title"]')?.setAttribute('content', t('metaTitle'));
        document.querySelector('meta[property="og:description"]')?.setAttribute('content', t('metaDescription'));
        document.querySelectorAll('[data-i18n]').forEach((element) => {
          element.textContent = t(element.dataset.i18n);
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach((element) => {
          element.placeholder = t(element.dataset.i18nPlaceholder);
        });
        document.querySelectorAll('[data-i18n-aria]').forEach((element) => {
          element.setAttribute('aria-label', t(element.dataset.i18nAria));
        });
        els.languageSelect.value = currentLanguage;
      }

      function periodLabel(period) {
        const periodCaptionKeys = {
          today: 'periodTodayCaption',
          week: 'periodWeekCaption',
          month: 'periodMonthCaption',
          year: 'periodYearCaption',
          alltime: 'periodAllCaption',
        };
        return t(periodCaptionKeys[period] || 'periodTodayCaption');
      }

      function localApi() {
        return `http://127.0.0.1:${servicePort}`;
      }

      function updatePortUi() {
        els.portInput.value = String(servicePort);
        els.localApiLabel.textContent = `127.0.0.1:${servicePort}`;
        els.installCommand.textContent = `bash typefreq-install-${servicePort}.sh`;
        els.manualInstallCommand.textContent = `./install.sh ${servicePort}`;
      }

      function updateW2lPortUi() {
        els.w2lPortInput.value = String(w2lPort);
      }

      function applyPort(value) {
        if (!isValidPort(value)) {
          setConnected(false, t('portInvalid'));
          return false;
        }
        servicePort = Number(value);
        localStorage.setItem(PORT_STORAGE_KEY, String(servicePort));
        updatePortUi();
        return true;
      }

      async function api(path, options = {}) {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);
        try {
          const response = await fetch(`${localApi()}${path}`, {
            mode: 'cors',
            signal: controller.signal,
            ...options,
          });
          if (!response.ok) {
            throw new Error(`${response.status} ${response.statusText}`);
          }
          return await response.json();
        } finally {
          clearTimeout(timer);
        }
      }

      function syncIntroText(connected) {
        const keys = connected ? {
          eyebrow: 'setupConnectedEyebrow',
          title: 'setupConnectedTitle',
          leadBefore: 'setupConnectedLeadBefore',
          leadAfter: 'setupConnectedLeadAfter',
        } : {
          eyebrow: 'setupEyebrow',
          title: 'setupTitle',
          leadBefore: 'setupLeadBefore',
          leadAfter: 'setupLeadAfter',
        };
        els.introEyebrow.dataset.i18n = keys.eyebrow;
        els.introTitle.dataset.i18n = keys.title;
        els.introLeadBefore.dataset.i18n = keys.leadBefore;
        els.introLeadAfter.dataset.i18n = keys.leadAfter;
        els.introEyebrow.textContent = t(keys.eyebrow);
        els.introTitle.textContent = t(keys.title);
        els.introLeadBefore.textContent = t(keys.leadBefore);
        els.introLeadAfter.textContent = t(keys.leadAfter);
      }

      function setConnected(connected, message = '') {
        connectionMode = connected ? 'connected' : 'offline';
        if (!connected) latestStatus = null;
        els.dashboard.hidden = !connected;
        els.setup.hidden = false;
        els.setup.classList.toggle('connected', connected);
        els.setupActions.hidden = connected;
        els.setupGuide.hidden = connected;
        els.pause.hidden = !connected;
        syncIntroText(connected);
        els.badge.className = `status-pill ${connected ? 'active' : 'offline'}`;
        els.badge.textContent = connected ? message || phrase('connectedOn', { port: servicePort }) : message || phrase('noServiceOn', { port: servicePort });
      }

      function setChecking() {
        connectionMode = 'checking';
        els.badge.className = 'status-pill checking';
        els.badge.textContent = t('statusChecking');
      }

      function renderNotice(status) {
        if (!status) return;
        const notices = [];
        if (status.paused) notices.push(t('noticePaused'));
        if (!status.paused && Number(status.active_keyboard_count || 0) === 0) {
          notices.push(t('noticeNoKeyboard'));
        }
        if (status.locker_active) notices.push(t('noticeLocked'));
        if (status.polkit_active) notices.push(t('noticePolkit'));
        els.notice.hidden = notices.length === 0;
        els.notice.textContent = notices.join(' ');
      }

      function renderTop(rows) {
        if (!rows.length) {
          els.topList.innerHTML = `<div class="empty">${esc(t('emptyTopWords'))}</div>`;
          return;
        }
        const max = rows.reduce((m, row) => Math.max(m, Number(row.count) || 0), 1);
        els.topList.innerHTML = rows.map((row, index) => {
          const count = Number(row.count) || 0;
          const pct = Math.max(3, (count / max) * 100);
          return `
            <div class="top-row" title="${esc(row.word)}: ${fmt(count)}">
              <span class="rank">${index + 1}</span>
              <span class="word">${esc(row.word)}</span>
              <span class="bar"><span style="width: ${pct}%"></span></span>
              <span class="count">${fmt(count)}</span>
            </div>
          `;
        }).join('');
      }

      function renderActiveLeaderboard() {
        if (!leaderboards) return;
        const data = leaderboards[activePeriod] || { top_words: [] };
        const rows = data.top_words || [];
        renderTop(rows);
        els.leaderboardCaption.textContent = phrase(rows.length === 1 ? 'leaderboardCaptionOne' : 'leaderboardCaptionMany', {
          period: periodLabel(activePeriod),
          count: fmt(rows.length),
        });
      }

      function renderHourly(rows) {
        if (!rows.length) {
          els.hourlyList.innerHTML = `<div class="empty">${esc(t('emptyHourly'))}</div>`;
          return;
        }
        const max = rows.reduce((m, row) => Math.max(m, Number(row.words) || 0, Number(row.typos) || 0), 1);
        els.hourlyList.innerHTML = rows.map((row) => {
          const wordsPct = Math.max(2, ((Number(row.words) || 0) / max) * 100);
          const typoPct = Math.max(0, ((Number(row.typos) || 0) / max) * 100);
          return `
            <div class="hour-row">
              <span>${fmtTime(row.hour)}</span>
              <span class="hour-bars">
                <span class="hour-word" style="width: ${wordsPct}%"></span>
                <span class="hour-typo" style="width: ${typoPct}%"></span>
              </span>
              <span>${fmt(row.words)}</span>
            </div>
          `;
        }).join('');
      }

      function renderTypos(rows) {
        if (!rows.length) {
          els.typoList.innerHTML = `<div class="empty">${esc(t('emptyTypos'))}</div>`;
          return;
        }
        els.typoList.innerHTML = rows.map((row) => `
          <div class="typo-row">
            <span class="time">${fmtTime(row.ts)}</span>
            <span class="bad">${esc(row.word)}</span>
            <span class="arrow">-></span>
            <span class="good">${esc(row.suggestion || '?')}</span>
            <button class="mini-btn" type="button" data-word="${esc(row.word)}">${esc(t('keep'))}</button>
          </div>
        `).join('');
        els.typoList.querySelectorAll('button[data-word]').forEach((button) => {
          button.addEventListener('click', () => addCustomWord(button.dataset.word));
        });
      }

      function renderCustomWords(words) {
        if (!words.length) {
          els.customList.innerHTML = `<div class="empty">${esc(t('emptyCustomWords'))}</div>`;
          return;
        }
        els.customList.innerHTML = words.map((row) => `
          <span class="chip">
            <span>${esc(row.word)}</span>
            <button type="button" data-word="${esc(row.word)}" aria-label="${esc(phrase('removeLabel', { word: row.word }))}">x</button>
          </span>
        `).join('');
        els.customList.querySelectorAll('button[data-word]').forEach((button) => {
          button.addEventListener('click', () => removeCustomWord(button.dataset.word));
        });
      }

      function setFeedback(message, kind = '') {
        els.customFeedback.textContent = message;
        els.customFeedback.className = `feedback ${kind}`.trim();
      }

      async function addCustomWord(word) {
        const value = String(word || '').trim();
        if (!value) return;
        const data = await api('/api/custom-words', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ word: value }),
        });
        renderCustomWords(data.words || []);
        setFeedback(data.added ? phrase('customAdded', { word: data.word }) : phrase('customAlreadyKept', { word: data.word }), 'ok');
        await refreshData();
      }

      async function removeCustomWord(word) {
        if (!word) return;
        const data = await api(`/api/custom-words/${encodeURIComponent(word)}`, { method: 'DELETE' });
        renderCustomWords(data.words || []);
        setFeedback(data.removed ? phrase('customRemoved', { word: data.word }) : phrase('customNotInList', { word: data.word }), 'ok');
      }

      async function refreshData() {
        const [status, today, boards, custom] = await Promise.all([
          api('/api/status'),
          api('/api/stats/today'),
          api('/api/stats/leaderboards'),
          api('/api/custom-words'),
        ]);
        latestStatus = status;
        leaderboards = boards;
        els.words.textContent = fmt(today.totals?.words);
        els.unique.textContent = fmt(today.totals?.unique_words);
        els.typos.textContent = fmt(today.totals?.typos);
        els.events.textContent = fmt(status.events_seen);
        els.pause.textContent = status.paused ? t('resume') : t('pause');
        const keyboardCount = Number(status.active_keyboard_count || 0);
        setConnected(true, status.paused ? phrase('connectedPaused', { port: servicePort }) : phrase(keyboardCount === 1 ? 'connectedKeyboardOne' : 'connectedKeyboardMany', { port: servicePort, count: keyboardCount }));
        renderNotice(status);
        renderHourly(today.hourly || []);
        renderTypos(today.recent_typos || []);
        renderCustomWords(custom.words || []);
        renderActiveLeaderboard();
      }

      async function connect() {
        setChecking();
        clearInterval(refreshTimer);
        try {
          const health = await api('/api/health');
          if (health.service !== 'typefreq') throw new Error('unexpected service');
          await refreshData();
          refreshTimer = setInterval(() => refreshData().catch(() => setConnected(false)), REFRESH_MS);
        } catch {
          setConnected(false);
          refreshW2lCard().catch(() => {});
        }
      }

      function installerScript(port, options = {}) {
        const web2local = Boolean(options.web2local);
        const archiveUrl = new URL(els.downloadInstaller.dataset.downloadHref, window.location.href).toString();
        const publicOrigin = window.location.origin;
        const allowedOrigins = [
          publicOrigin,
          'https://keyfreq.lue-app.com',
          'http://localhost:4321',
          'http://127.0.0.1:4321',
          'http://localhost:4325',
          'http://127.0.0.1:4325',
        ].join(',');
        const web2localPrelude = web2local ? `
# web2local runs commands without terminal stdin, so avoid sudo paths and fail
# with a readable prerequisite message instead of prompting invisibly.
if ! getent group input >/dev/null 2>&1; then
  echo "The input group does not exist. Use the terminal installer on an Ubuntu-style desktop." >&2
  exit 1
fi
if id -nG | tr ' ' '\\n' | grep -qx input; then
  :
elif getent group input | awk -F: -v u="$USER" 'BEGIN{r=1} {n=split($4,a,","); for(i=1;i<=n;i++) if (a[i]==u) r=0} END{exit r}'; then
  :
else
  echo "web2local cannot ask for a sudo password to add $USER to the input group." >&2
  echo "Run the configured installer in a terminal once, then sign out and back in if needed." >&2
  exit 1
fi
export TYPEFREQ_SKIP_APT="1"
` : '';
        return `#!/usr/bin/env bash
set -euo pipefail

TYPEFREQ_PORT="${port}"
TYPEFREQ_PUBLIC_SITE="${publicOrigin}"
TYPEFREQ_ALLOWED_ORIGINS="${allowedOrigins}"
ARCHIVE_URL="${archiveUrl}"
INSTALL_DIR="\${TYPEFREQ_INSTALL_DIR:-$HOME/.local/lib/typefreq}"
WORK_DIR="$(mktemp -d)"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT

case "$INSTALL_DIR" in
  ""|"/"|"$HOME"|"$HOME/"|"$HOME/."|"$HOME/.local/share/typefreq"|"$HOME/.local/share/typefreq/"|"$HOME/.local/share/keyfreq"|"$HOME/.local/share/keyfreq/")
    echo "Refusing unsafe TYPEFREQ_INSTALL_DIR: $INSTALL_DIR" >&2
    exit 1
    ;;
esac

${web2localPrelude}

if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$ARCHIVE_URL" -o "$WORK_DIR/typefreq-latest.tar"
elif command -v wget >/dev/null 2>&1; then
  wget -qO "$WORK_DIR/typefreq-latest.tar" "$ARCHIVE_URL"
else
  echo "curl or wget is required to download Typefreq." >&2
  exit 1
fi

tar -xf "$WORK_DIR/typefreq-latest.tar" -C "$WORK_DIR"
mkdir -p "$(dirname "$INSTALL_DIR")"
rm -rf "$INSTALL_DIR.next"
mv "$WORK_DIR/typefreq" "$INSTALL_DIR.next"
rm -rf "$INSTALL_DIR"
mv "$INSTALL_DIR.next" "$INSTALL_DIR"
cd "$INSTALL_DIR"
TYPEFREQ_PORT="$TYPEFREQ_PORT" TYPEFREQ_PUBLIC_SITE="$TYPEFREQ_PUBLIC_SITE" TYPEFREQ_ALLOWED_ORIGINS="$TYPEFREQ_ALLOWED_ORIGINS" ./install.sh "$TYPEFREQ_PORT"
`;
      }

      function downloadConfiguredInstaller() {
        if (!applyPort(els.portInput.value)) return;
        const blob = new Blob([installerScript(servicePort)], { type: 'text/x-shellscript' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `typefreq-install-${servicePort}.sh`;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function sleep(ms) {
        return new Promise((resolve) => setTimeout(resolve, ms));
      }

      function w2lBase() {
        return `http://127.0.0.1:${w2lPort}`;
      }

      function w2lOriginUsable() {
        return window.location.origin !== 'null' && /^https?:$/i.test(window.location.protocol);
      }

      const W2L_CHIP_KEYS = {
        checking: 'w2lChecking',
        absent: 'w2lAbsent',
        present: 'w2lDetected',
        approving: 'w2lWorking',
        installing: 'w2lInstalling',
        installed: 'w2lReady',
        error: 'w2lErrorChip',
      };

      function setW2lState(state) {
        w2lState = state;
        els.w2lStatus.dataset.state = state;
        els.w2lStatus.textContent = t(W2L_CHIP_KEYS[state] || 'w2lChecking');
        const busy = state === 'checking' || state === 'approving' || state === 'installing';
        const canInstall = state === 'present' || state === 'error';
        els.w2lCheck.disabled = busy;
        els.w2lInstall.disabled = w2lBusy || !canInstall;
        els.w2lGet.hidden = !(state === 'absent');
      }

      function setW2lMessage(key, values = null) {
        w2lMessageKey = key;
        w2lMessageValues = values;
        els.w2lMessage.textContent = key ? phrase(key, values || {}) : '';
      }

      function renderW2lText() {
        setW2lState(w2lState);
        els.w2lMessage.textContent = w2lMessageKey ? phrase(w2lMessageKey, w2lMessageValues || {}) : '';
      }

      async function sha256Hex(text) {
        if (!(window.crypto && crypto.subtle)) return null;
        const bytes = new TextEncoder().encode(text);
        const digest = await crypto.subtle.digest('SHA-256', bytes);
        return [...new Uint8Array(digest)].map((byte) => byte.toString(16).padStart(2, '0')).join('');
      }

      async function w2lFetch(path, options = {}, timeoutMs = W2L_REQUEST_TIMEOUT_MS) {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), timeoutMs);
        try {
          return await fetch(`${w2lBase()}${path}`, {
            mode: 'cors',
            signal: controller.signal,
            ...options,
          });
        } finally {
          clearTimeout(timer);
        }
      }

      async function w2lPostJson(path, body, timeoutMs) {
        const response = await w2lFetch(path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body || {}),
        }, timeoutMs);
        let data = {};
        try { data = await response.json(); } catch { /* tolerate empty/non-JSON */ }
        if (!response.ok) throw new Error(data.error || `${response.status} ${response.statusText}`);
        return data;
      }

      async function refreshW2lCard() {
        if (w2lBusy || !els.w2lCard || els.setupGuide.hidden) return;
        if (!w2lOriginUsable()) {
          setW2lState('absent');
          setW2lMessage('w2lOpaqueOrigin');
          return;
        }
        setW2lState('checking');
        try {
          const response = await w2lFetch('/status');
          if (!response.ok) throw new Error('not detected');
          setW2lState('present');
          setW2lMessage('w2lHintIdle', { port: w2lPort, servicePort });
        } catch {
          setW2lState('absent');
          setW2lMessage('w2lHintAbsent', { port: w2lPort });
        }
      }

      async function showW2lLog(pid) {
        if (!pid) return;
        try {
          const response = await w2lFetch(`/logs?pid=${encodeURIComponent(pid)}`);
          if (!response.ok) return;
          const data = await response.json();
          if (data.tail) {
            els.w2lLog.textContent = data.tail;
            els.w2lLog.hidden = false;
          }
        } catch { /* logs are best effort */ }
      }

      async function pollServiceInstalled(maxMs, pid) {
        const started = Date.now();
        let nextLogAt = 0;
        while (Date.now() - started < maxMs) {
          try {
            const health = await api('/api/health');
            if (health.service === 'typefreq') return true;
          } catch { /* service is not up yet */ }
          if (pid && Date.now() >= nextLogAt) {
            await showW2lLog(pid);
            nextLogAt = Date.now() + 5000;
          }
          await sleep(2500);
        }
        return false;
      }

      function handleW2lError(error) {
        if (error?.name === 'AbortError') {
          setW2lMessage('w2lApprovalTimeout');
          return;
        }
        const message = error?.message || String(error);
        if (/denied/i.test(message)) setW2lMessage('w2lDenied');
        else if (/bash|command not found|executable/i.test(message)) setW2lMessage('w2lNoBash');
        else if (/origin|whitelist|graylist/i.test(message)) setW2lMessage('w2lOriginRejected');
        else setW2lMessage('w2lError', { msg: message });
      }

      function applyW2lPort() {
        if (!isValidAnyPort(els.w2lPortInput.value)) {
          setW2lState('error');
          setW2lMessage('w2lPortInvalid');
          return false;
        }
        w2lPort = Number(els.w2lPortInput.value);
        localStorage.setItem(W2L_PORT_STORAGE_KEY, String(w2lPort));
        updateW2lPortUi();
        return true;
      }

      async function installWithWeb2Local() {
        if (w2lBusy) return;
        if (!applyPort(els.portInput.value) || !applyW2lPort()) return;
        if (!w2lOriginUsable()) {
          setW2lState('absent');
          setW2lMessage('w2lOpaqueOrigin');
          return;
        }

        w2lBusy = true;
        els.w2lLog.hidden = true;
        els.w2lLog.textContent = '';
        setW2lState('approving');
        setW2lMessage('w2lApprove');

        let pid = null;
        try {
          const source = installerScript(servicePort, { web2local: true });
          const sha256 = await sha256Hex(source);
          if (!sha256) {
            setW2lState('error');
            setW2lMessage('w2lHashUnavailable');
            return;
          }
          await w2lPostJson('/config/graylist', { origin: window.location.origin });
          const deployed = await w2lPostJson('/deploy', {
            source,
            sha256,
            filename: `typefreq-install-${servicePort}.sh`,
            command: 'bash',
            args: [],
          }, W2L_DEPLOY_TIMEOUT_MS);
          pid = deployed.pid || null;
          setW2lState('installing');
          setW2lMessage('w2lInstallingMsg');
          const installed = await pollServiceInstalled(W2L_INSTALL_TIMEOUT_MS, pid);
          if (installed) {
            setW2lState('installed');
            setW2lMessage('w2lInstalled', { port: servicePort });
            await connect();
          } else {
            await showW2lLog(pid);
            setW2lState('error');
            setW2lMessage('w2lTimeout');
          }
        } catch (error) {
          setW2lState('error');
          handleW2lError(error);
          await showW2lLog(pid);
        } finally {
          w2lBusy = false;
          renderW2lText();
        }
      }

      document.querySelectorAll('#leaderboard-tabs .tab').forEach((button) => {
        button.addEventListener('click', () => {
          activePeriod = button.dataset.period;
          document.querySelectorAll('#leaderboard-tabs .tab').forEach((tab) => {
            tab.classList.toggle('active', tab === button);
          });
          renderActiveLeaderboard();
        });
      });

      els.retry.addEventListener('click', connect);
      els.setupRetry.addEventListener('click', connect);
      els.downloadInstaller.addEventListener('click', downloadConfiguredInstaller);
      els.setupDownloadInstaller.addEventListener('click', downloadConfiguredInstaller);
      els.w2lCheck.addEventListener('click', () => {
        if (applyW2lPort()) refreshW2lCard();
      });
      els.w2lInstall.addEventListener('click', installWithWeb2Local);
      els.languageSelect.addEventListener('change', async () => {
        const nextLanguage = els.languageSelect.value;
        if (!translations[nextLanguage]) return;
        const shouldRefreshDashboard = !els.dashboard.hidden;
        currentLanguage = nextLanguage;
        localStorage.setItem(LANGUAGE_STORAGE_KEY, currentLanguage);
        syncLanguageStaticText();
        renderW2lText();
        if (connectionMode === 'checking') {
          setChecking();
        } else if (shouldRefreshDashboard) {
          try {
            await refreshData();
          } catch {
            setConnected(false);
          }
        } else {
          setConnected(false);
        }
      });
      els.portForm.addEventListener('submit', (event) => {
        event.preventDefault();
        if (applyPort(els.portInput.value)) connect();
      });
      els.pause.addEventListener('click', async () => {
        await api('/api/pause', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paused: !latestStatus?.paused }),
        });
        await refreshData();
      });
      els.customForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const value = els.customInput.value.trim();
        if (!value) return;
        try {
          await addCustomWord(value);
          els.customInput.value = '';
        } catch (error) {
          setFeedback(error.message || t('couldNotAddWord'), 'err');
        }
      });

      syncLanguageStaticText();
      updatePortUi();
      updateW2lPortUi();
      connect();
    </script>
  </body>
</html>
